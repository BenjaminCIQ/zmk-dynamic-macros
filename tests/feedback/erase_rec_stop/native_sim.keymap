#include "../behavior_keymap.dtsi"

&kscan {
    events = <
        /* REC: types ">*", then auto-erase fires (500ms delay) and types 2 backspaces.
         * State must be RECORDING after erase completes, not IDLE. */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,2000)
        /* STP: only works if state is RECORDING after erase; types ">." */
        ZMK_MOCK_PRESS(0,1,10)
        ZMK_MOCK_RELEASE(0,1,2000)
        /* SLOT_RAM 0: assign; only works if state is PENDING_ASSIGN; types ">R0" */
        ZMK_MOCK_PRESS(1,0,10)
        ZMK_MOCK_RELEASE(1,0,2000)
    >;
};
