 *
 * Test: Record a key sequence and play it back from NVS slot.
 *
 * Sequence:
 * 1. Press REC to start recording
 * 2. Press A
 * 3. Press STP to stop recording (also assigns to slot 0)
 * 4. Press slot 0 to playback
 *
 * Expected: Playback emits A key events
 */

#include "../behavior_keymap.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0        /* 0,0: start recording */
                &dm DM_STP 0        /* 0,1: stop recording */
                &dm DM_SLOT_NVS 0   /* 1,0: NVS slot 0 (assign/play) */
                &kp A               /* 1,1: key A */
            >;
        };
    };
};

&kscan {
    events = <
        /* Start recording */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,10)

        /* Record: A */
        ZMK_MOCK_PRESS(1,1,10)
        ZMK_MOCK_RELEASE(1,1,10)

        /* Stop recording */
        ZMK_MOCK_PRESS(0,1,10)
        ZMK_MOCK_RELEASE(0,1,10)

        /* Assign to slot 0 */
        ZMK_MOCK_PRESS(1,0,10)
        ZMK_MOCK_RELEASE(1,0,10)

        /* Playback */
        ZMK_MOCK_PRESS(1,0,2000)
        ZMK_MOCK_RELEASE(1,0,10)
    >;
};
