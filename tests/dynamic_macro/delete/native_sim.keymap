 *
 * Test: Record macro, save, then delete it.
 *
 * Sequence:
 * 1. Record A, save to slot 0
 * 2. Play slot 0 (should work)
 * 3. Press DEL to enter delete mode
 * 4. Press slot 0 to delete
 * 5. Play slot 0 again (should be empty)
 *
 * Expected: First playback works, second fails (empty)
 */

#include "../behavior_keymap.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0        /* 0,0 */
                &dm DM_STP 0        /* 0,1 */
                &dm DM_SLOT_NVS 0   /* 1,0 */
                &dm DM_DEL 0        /* 1,1 */
            >;
        };
        extra_layer {
            bindings = <
                &kp A &none
                &none &none
            >;
        };
    };
};

&kscan {
    events = <
        /* Record: use behavior queue to record A via slot command */
        /* Start recording */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,10)

        /* Stop recording (records empty macro for simplicity) */
        ZMK_MOCK_PRESS(0,1,10)
        ZMK_MOCK_RELEASE(0,1,10)

        /* Assign to slot 0 */
        ZMK_MOCK_PRESS(1,0,10)
        ZMK_MOCK_RELEASE(1,0,10)

        /* Enter delete mode */
        ZMK_MOCK_PRESS(1,1,1000)
        ZMK_MOCK_RELEASE(1,1,10)

        /* Delete slot 0 */
        ZMK_MOCK_PRESS(1,0,10)
        ZMK_MOCK_RELEASE(1,0,10)

        /* Try play slot 0 - should be empty now */
        ZMK_MOCK_PRESS(1,0,2000)
        ZMK_MOCK_RELEASE(1,0,10)
    >;
};
