 *
 * Test: Record then let assign timeout expire without saving.
 *
 * Sequence:
 * 1. Press REC to start recording
 * 2. Press A
 * 3. Press STP to stop recording
 * 4. Wait for ASSIGN_TIMEOUT (default 10s) without pressing slot
 *
 * Expected: Recording discarded, state returns to IDLE
 */

#include "../behavior_keymap.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0        /* 0,0 */
                &dm DM_STP 0        /* 0,1 */
                &dm DM_SLOT_NVS 0   /* 1,0 */
                &kp A               /* 1,1 */
            >;
        };
    };
};

&kscan {
    events = <
        /* Start recording */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,10)

        /* Record: A */
        ZMK_MOCK_PRESS(1,1,10)
        ZMK_MOCK_RELEASE(1,1,10)

        /* Stop recording */
        ZMK_MOCK_PRESS(0,1,10)
        ZMK_MOCK_RELEASE(0,1,10)

        /* Wait for timeout (10s+) then try to play - should be empty */
        ZMK_MOCK_PRESS(1,0,15000)
        ZMK_MOCK_RELEASE(1,0,10)
    >;
};
