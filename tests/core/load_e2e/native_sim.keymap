#include <dt-bindings/zmk/keys.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/kscan_mock.h>
#include <behaviors/dynamic_macro.dtsi>
#include <dt-bindings/zmk/dynamic_macros.h>

/* End-to-end load test: 4 RAM slots, MAX_EVENTS=20, all slots filled to capacity.
 *
 * Key layout (8 rows x 2 cols):
 *   (0,0)=REC      (0,1)=STP
 *   (1,0)=SLOT_RAM0 (1,1)=SLOT_RAM1
 *   (2,0)=SLOT_RAM2 (2,1)=SLOT_RAM3
 *   (3,0)=A        (3,1)=B
 *   (4,0)=LSHFT    (4,1)=LCTRL
 *   (5,0)=Z        (5,1)=LEFT
 *   (6,0)=RIGHT    (6,1)=UP
 *   (7,0)=DOWN     (7,1)=MOV
 *   Note: DEL uses row 8 — added as a 9th row
 *   (8,0)=DEL      (8,1)=none
 *
 * Sequences (each = 20 events):
 *   slot 0: LEFT RIGHT UP DOWN LEFT RIGHT UP DOWN LEFT RIGHT  (10x arrow = 20)
 *   slot 1: Shift+A Shift+B Ctrl+Z Shift+A LEFT RIGHT        (4+4+4+4+2+2 = 20)
 *   slot 2: A B LEFT Shift+A RIGHT Ctrl+Z UP DOWN            (2+2+2+4+2+4+2+2 = 20)
 *   slot 3 (via move from slot 1, then re-record slot 1):
 *     slot 1 re-record: Ctrl+Z Ctrl+Z Ctrl+Z Shift+A Shift+B  (4+4+4+4+4 = 20)
 *
 * Flow:
 *   Phase 1: record slots 0, 1, 2
 *   Phase 2: move slot 1 -> slot 3
 *   Phase 3: re-record slot 1 (all 4 slots now at capacity)
 *   Phase 4: play all 4 slots, verify output
 *   Phase 5: delete slot 2, play slot 2 (empty), play slot 3 (intact) */

&kscan {
    rows = <9>;
    columns = <2>;
    exit-after;
    events = <
        /* ===== Phase 1: record slots 0, 1, 2 ===== */

        /* Record slot 0: LEFT RIGHT UP DOWN LEFT RIGHT UP DOWN LEFT RIGHT (20 events) */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,10)
        ZMK_MOCK_PRESS(5,1,10)   /* LEFT */
        ZMK_MOCK_RELEASE(5,1,10)
        ZMK_MOCK_PRESS(6,0,10)   /* RIGHT */
        ZMK_MOCK_RELEASE(6,0,10)
        ZMK_MOCK_PRESS(6,1,10)   /* UP */
        ZMK_MOCK_RELEASE(6,1,10)
        ZMK_MOCK_PRESS(7,0,10)   /* DOWN */
        ZMK_MOCK_RELEASE(7,0,10)
        ZMK_MOCK_PRESS(5,1,10)   /* LEFT */
        ZMK_MOCK_RELEASE(5,1,10)
        ZMK_MOCK_PRESS(6,0,10)   /* RIGHT */
        ZMK_MOCK_RELEASE(6,0,10)
        ZMK_MOCK_PRESS(6,1,10)   /* UP */
        ZMK_MOCK_RELEASE(6,1,10)
        ZMK_MOCK_PRESS(7,0,10)   /* DOWN */
        ZMK_MOCK_RELEASE(7,0,10)
        ZMK_MOCK_PRESS(5,1,10)   /* LEFT */
        ZMK_MOCK_RELEASE(5,1,10)
        ZMK_MOCK_PRESS(6,0,10)   /* RIGHT */
        ZMK_MOCK_RELEASE(6,0,10)
        ZMK_MOCK_PRESS(0,1,10)
        ZMK_MOCK_RELEASE(0,1,10)
        ZMK_MOCK_PRESS(1,0,10)
        ZMK_MOCK_RELEASE(1,0,10)

        /* Record slot 1: Shift+A Shift+B Ctrl+Z Shift+A LEFT RIGHT (20 events) */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,10)
        ZMK_MOCK_PRESS(4,0,10)   /* Shift down */
        ZMK_MOCK_PRESS(3,0,10)   /* A */
        ZMK_MOCK_RELEASE(3,0,10)
        ZMK_MOCK_RELEASE(4,0,10) /* Shift up */
        ZMK_MOCK_PRESS(4,0,10)   /* Shift down */
        ZMK_MOCK_PRESS(3,1,10)   /* B */
        ZMK_MOCK_RELEASE(3,1,10)
        ZMK_MOCK_RELEASE(4,0,10) /* Shift up */
        ZMK_MOCK_PRESS(4,1,10)   /* Ctrl down */
        ZMK_MOCK_PRESS(5,0,10)   /* Z */
        ZMK_MOCK_RELEASE(5,0,10)
        ZMK_MOCK_RELEASE(4,1,10) /* Ctrl up */
        ZMK_MOCK_PRESS(4,0,10)   /* Shift down */
        ZMK_MOCK_PRESS(3,0,10)   /* A */
        ZMK_MOCK_RELEASE(3,0,10)
        ZMK_MOCK_RELEASE(4,0,10) /* Shift up */
        ZMK_MOCK_PRESS(5,1,10)   /* LEFT */
        ZMK_MOCK_RELEASE(5,1,10)
        ZMK_MOCK_PRESS(6,0,10)   /* RIGHT */
        ZMK_MOCK_RELEASE(6,0,10)
        ZMK_MOCK_PRESS(0,1,10)
        ZMK_MOCK_RELEASE(0,1,10)
        ZMK_MOCK_PRESS(1,1,10)
        ZMK_MOCK_RELEASE(1,1,10)

        /* Record slot 2: A B LEFT Shift+A RIGHT Ctrl+Z UP DOWN (20 events) */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,10)
        ZMK_MOCK_PRESS(3,0,10)   /* A */
        ZMK_MOCK_RELEASE(3,0,10)
        ZMK_MOCK_PRESS(3,1,10)   /* B */
        ZMK_MOCK_RELEASE(3,1,10)
        ZMK_MOCK_PRESS(5,1,10)   /* LEFT */
        ZMK_MOCK_RELEASE(5,1,10)
        ZMK_MOCK_PRESS(4,0,10)   /* Shift down */
        ZMK_MOCK_PRESS(3,0,10)   /* A */
        ZMK_MOCK_RELEASE(3,0,10)
        ZMK_MOCK_RELEASE(4,0,10) /* Shift up */
        ZMK_MOCK_PRESS(6,0,10)   /* RIGHT */
        ZMK_MOCK_RELEASE(6,0,10)
        ZMK_MOCK_PRESS(4,1,10)   /* Ctrl down */
        ZMK_MOCK_PRESS(5,0,10)   /* Z */
        ZMK_MOCK_RELEASE(5,0,10)
        ZMK_MOCK_RELEASE(4,1,10) /* Ctrl up */
        ZMK_MOCK_PRESS(6,1,10)   /* UP */
        ZMK_MOCK_RELEASE(6,1,10)
        ZMK_MOCK_PRESS(7,0,10)   /* DOWN */
        ZMK_MOCK_RELEASE(7,0,10)
        ZMK_MOCK_PRESS(0,1,10)
        ZMK_MOCK_RELEASE(0,1,10)
        ZMK_MOCK_PRESS(2,0,10)
        ZMK_MOCK_RELEASE(2,0,10)

        /* ===== Phase 2: move slot 1 -> slot 3 ===== */
        ZMK_MOCK_PRESS(7,1,10)
        ZMK_MOCK_RELEASE(7,1,10)
        ZMK_MOCK_PRESS(1,1,10)   /* source: slot 1 */
        ZMK_MOCK_RELEASE(1,1,10)
        ZMK_MOCK_PRESS(2,1,10)   /* destination: slot 3 */
        ZMK_MOCK_RELEASE(2,1,10)

        /* ===== Phase 3: re-record slot 1: Ctrl+Z Ctrl+Z Ctrl+Z Shift+A Shift+B (20 events) ===== */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,10)
        ZMK_MOCK_PRESS(4,1,10)   /* Ctrl down */
        ZMK_MOCK_PRESS(5,0,10)   /* Z */
        ZMK_MOCK_RELEASE(5,0,10)
        ZMK_MOCK_RELEASE(4,1,10) /* Ctrl up */
        ZMK_MOCK_PRESS(4,1,10)   /* Ctrl down */
        ZMK_MOCK_PRESS(5,0,10)   /* Z */
        ZMK_MOCK_RELEASE(5,0,10)
        ZMK_MOCK_RELEASE(4,1,10) /* Ctrl up */
        ZMK_MOCK_PRESS(4,1,10)   /* Ctrl down */
        ZMK_MOCK_PRESS(5,0,10)   /* Z */
        ZMK_MOCK_RELEASE(5,0,10)
        ZMK_MOCK_RELEASE(4,1,10) /* Ctrl up */
        ZMK_MOCK_PRESS(4,0,10)   /* Shift down */
        ZMK_MOCK_PRESS(3,0,10)   /* A */
        ZMK_MOCK_RELEASE(3,0,10)
        ZMK_MOCK_RELEASE(4,0,10) /* Shift up */
        ZMK_MOCK_PRESS(4,0,10)   /* Shift down */
        ZMK_MOCK_PRESS(3,1,10)   /* B */
        ZMK_MOCK_RELEASE(3,1,10)
        ZMK_MOCK_RELEASE(4,0,10) /* Shift up */
        ZMK_MOCK_PRESS(0,1,10)
        ZMK_MOCK_RELEASE(0,1,10)
        ZMK_MOCK_PRESS(1,1,10)
        ZMK_MOCK_RELEASE(1,1,10)

        /* ===== Phase 4: play all slots ===== */
        ZMK_MOCK_PRESS(1,0,2000)
        ZMK_MOCK_RELEASE(1,0,10)
        ZMK_MOCK_PRESS(1,1,2000)
        ZMK_MOCK_RELEASE(1,1,10)
        ZMK_MOCK_PRESS(2,0,2000)
        ZMK_MOCK_RELEASE(2,0,10)
        ZMK_MOCK_PRESS(2,1,2000)
        ZMK_MOCK_RELEASE(2,1,10)

        /* ===== Phase 5: delete slot 2 ===== */
        ZMK_MOCK_PRESS(8,0,10)
        ZMK_MOCK_RELEASE(8,0,10)
        ZMK_MOCK_PRESS(2,0,10)   /* confirm: slot 2 */
        ZMK_MOCK_RELEASE(2,0,10)
        /* play slot 2: empty, no output */
        ZMK_MOCK_PRESS(2,0,200)
        ZMK_MOCK_RELEASE(2,0,10)
        /* play slot 3: Shift+A Shift+B Ctrl+Z Shift+A LEFT RIGHT */
        ZMK_MOCK_PRESS(2,1,2000)
        ZMK_MOCK_RELEASE(2,1,10)
    >;
};

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0      &dm DM_STP 0
                &dm DM_SLOT_RAM 0 &dm DM_SLOT_RAM 1
                &dm DM_SLOT_RAM 2 &dm DM_SLOT_RAM 3
                &kp A             &kp B
                &kp LSHFT         &kp LCTRL
                &kp Z             &kp LEFT
                &kp RIGHT         &kp UP
                &kp DOWN          &dm DM_MOV 0
                &dm DM_DEL 0      &none
            >;
        };
    };
};
