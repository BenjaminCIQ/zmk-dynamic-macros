#include <dt-bindings/zmk/keys.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/kscan_mock.h>
#include <behaviors/dynamic_macro.dtsi>
#include <dt-bindings/zmk/dynamic_macros.h>

/* Shared-arena pool-full test.
 *
 * Pool sizing: AVG_EVENTS_PER_SLOT=2 x RAM_SLOTS=3 => ARENA_EVENTS = 6 events.
 * MAX_EVENTS=8 (a single macro may exceed the average; the pool is the cap).
 *
 * Key layout (4 rows x 2 cols):
 *   (0,0)=REC        (0,1)=STP
 *   (1,0)=SLOT_RAM0  (1,1)=SLOT_RAM1
 *   (2,0)=SLOT_RAM2  (2,1)=A
 *   (3,0)=B          (3,1)=C
 *
 * Flow:
 *   1. Record A once (2 events), assign slot 0   -> stored, pool 2/6.
 *   2. Record B twice (4 events), assign slot 1  -> stored, pool 6/6 (FULL).
 *   3. Record C once (2 events), assign slot 2   -> REJECTED (pool full); the
 *      live C keypress still passes through, but nothing is stored and the
 *      machine stays in PENDING_ASSIGN.
 *   4. Wait past ASSIGN_TIMEOUT (500ms) -> pending assign auto-cancels to IDLE.
 *   5. Play slot 2 -> empty, no output (proves the third macro was NOT stored).
 *   6. Play slot 0 -> A (proves slot 0 survived the full pool intact).
 *   7. Play slot 1 -> B B (proves slot 1 survived intact).
 *
 * With FEEDBACK_OFF the only emitted keycodes are the live record passthrough
 * plus playback, so the snapshot reads:
 *   A A          (live record, slot 0)
 *   B B B B      (live record, slot 1)
 *   C C          (live record, slot 2 — rejected assign, passthrough only)
 *   A A          (play slot 0)
 *   B B B B      (play slot 1)
 */

&kscan {
    rows = <4>;
    columns = <2>;
    exit-after;
    events = <
        /* ===== 1. record A, assign slot 0 ===== */
        ZMK_MOCK_PRESS(0,0,10)    /* REC */
        ZMK_MOCK_RELEASE(0,0,10)
        ZMK_MOCK_PRESS(2,1,10)    /* A */
        ZMK_MOCK_RELEASE(2,1,10)
        ZMK_MOCK_PRESS(0,1,10)    /* STP */
        ZMK_MOCK_RELEASE(0,1,10)
        ZMK_MOCK_PRESS(1,0,10)    /* SLOT_RAM 0 */
        ZMK_MOCK_RELEASE(1,0,10)

        /* ===== 2. record B twice (fills the pool), assign slot 1 ===== */
        ZMK_MOCK_PRESS(0,0,10)    /* REC */
        ZMK_MOCK_RELEASE(0,0,10)
        ZMK_MOCK_PRESS(3,0,10)    /* B */
        ZMK_MOCK_RELEASE(3,0,10)
        ZMK_MOCK_PRESS(3,0,10)    /* B */
        ZMK_MOCK_RELEASE(3,0,10)
        ZMK_MOCK_PRESS(0,1,10)    /* STP */
        ZMK_MOCK_RELEASE(0,1,10)
        ZMK_MOCK_PRESS(1,1,10)    /* SLOT_RAM 1 */
        ZMK_MOCK_RELEASE(1,1,10)

        /* ===== 3. record C, attempt assign slot 2 -> rejected (pool full) ===== */
        ZMK_MOCK_PRESS(0,0,10)    /* REC */
        ZMK_MOCK_RELEASE(0,0,10)
        ZMK_MOCK_PRESS(3,1,10)    /* C */
        ZMK_MOCK_RELEASE(3,1,10)
        ZMK_MOCK_PRESS(0,1,10)    /* STP */
        ZMK_MOCK_RELEASE(0,1,10)
        ZMK_MOCK_PRESS(2,0,10)    /* SLOT_RAM 2 -> REJECTED_FULL, stays PENDING_ASSIGN */
        ZMK_MOCK_RELEASE(2,0,1000) /* 4. wait > ASSIGN_TIMEOUT (500ms): auto-cancel to IDLE */

        /* ===== 5. play slot 2: empty, no output ===== */
        ZMK_MOCK_PRESS(2,0,200)
        ZMK_MOCK_RELEASE(2,0,10)

        /* ===== 6. play slot 0: A ===== */
        ZMK_MOCK_PRESS(1,0,2000)
        ZMK_MOCK_RELEASE(1,0,10)

        /* ===== 7. play slot 1: B B ===== */
        ZMK_MOCK_PRESS(1,1,2000)
        ZMK_MOCK_RELEASE(1,1,10)
    >;
};

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0      &dm DM_STP 0
                &dm DM_SLOT_RAM 0 &dm DM_SLOT_RAM 1
                &dm DM_SLOT_RAM 2 &kp A
                &kp B             &kp C
            >;
        };
    };
};
